MONGODB_URI=

AUTH_SECRET=
# Optional locally — set if dev server is not on port 3000
AUTH_URL=http://localhost:3000
# Optional — public site URL for profile links (defaults to localhost:3000)
NEXT_PUBLIC_APP_URL=

# --- Vercel production (set in Vercel project → Settings → Environment Variables) ---
# AUTH_SECRET=          (required — generate with: openssl rand -base64 32)
# MONGODB_URI=          (required — Atlas connection string)
# AUTH_URL=https://your-app.vercel.app   (recommended — your deployment URL)
# ADMIN_EMAIL=          (optional)
# In MongoDB Atlas → Network Access, allow 0.0.0.0/0 so Vercel can connect.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Google OAuth redirect URI (add in Google Cloud Console → Credentials → your OAuth client):
#   Local:       http://localhost:3000/api/auth/callback/google
#   Production:  https://YOUR-DOMAIN/api/auth/callback/google
# Also add Authorized JavaScript origins: http://localhost:3000 and https://YOUR-DOMAIN
# AUTH_URL must match the domain you use (no trailing slash).
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
ADMIN_EMAIL=

GOOGLE_BOOKS_API_KEY=
THEBOOKDB_API_KEY=
ISBNDB_API_KEY=
